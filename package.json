{
  "name": "agingdeveloper",
  "private": true,
  "description": "The personal site of Richard Klein",
  "version": "6.0.0",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "clean": "rm -rf .astro dist node_modules",
    "upgrade:astro": "pnpm dlx @astrojs/upgrade",
    "upgrade:tailwind": "pnpm dlx @tailwindcss/upgrade",
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "netlify dev",
    "preview:build": "pnpm run build && netlify dev",
    "lint": "eslint \"**/*.{js,mjs,cjs,ts,astro}\"",
    "lint:fix": "eslint --fix \"**/*.{js,mjs,cjs,ts,astro}\"",
    "format": "prettier --check \"**/*.{js,mjs,cjs,ts,astro,md,mdx}\"",
    "format:fix": "prettier --write \"**/*.{js,mjs,cjs,ts,astro,md,mdx}\"",
    "test": "vitest run",
    "test:verbose": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "verify": "pnpm run lint && pnpm run format && pnpm run test && pnpm run build",
    "licenses": "license-report --output=table",
    "licenses:html": "license-report --output=html > license-report.html"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/netlify": "^7.0.6",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/fira-code": "^5.0.18",
    "@fontsource/noto-sans-georgian": "^5.0.22",
    "@fontsource/noto-serif-georgian": "^5.0.20",
    "@fontsource/walter-turncoat": "^5.1.0",
    "@iconify-json/mdi": "^1.1.66",
    "@sindresorhus/slugify": "^3.0.0",
    "@tailwindcss/typography": "^0.5.13",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^6.1.3",
    "astro-fuse": "^1.0.1",
    "astro-icon": "^1.1.1",
    "feed": "^5.0.0",
    "fuse.js": "^7.0.0",
    "license-report": "^6.7.1",
    "markdown-it": "^14.1.0",
    "mdast-util-to-string": "^4.0.0",
    "mime": "^4.0.4",
    "reading-time": "^1.5.0",
    "sanitize-html": "^2.13.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.4",
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.11.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.1.14",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.2.3",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "netlify-cli": "^23.5.0",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "skills": "^1.4.8",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.15.0",
    "vitest": "^4.0.18"
  }
}
